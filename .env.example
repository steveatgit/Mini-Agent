# Mini Agent local secrets.
# Copy this file to .env and fill in real values. .env is ignored by Git.

MINI_AGENT_API_KEY=YOUR_API_KEY_HERE

# Optional LLM overrides.
# MINI_AGENT_API_BASE=https://api.minimax.io
# MINI_AGENT_MODEL=MiniMax-M2.5
# MINI_AGENT_PROVIDER=anthropic

# Optional web search tool.
TAVILY_API_KEY=

# Optional Jira reader tool.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
